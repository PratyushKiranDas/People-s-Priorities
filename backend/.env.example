# People's Priorities - offline hackathon demo

# Add your Gemini Developer API key here.
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Offline data paths
# Submissions are saved by main.py at data/submissions.json.
USE_BIGQUERY=false
DEMOGRAPHICS_CSV_PATH=data/demographics_sample.csv

# Demo reliability: if Gemini credentials/network fail, ai_engine.py returns a
# deterministic local analysis instead of blocking the submission flow.
ENABLE_LOCAL_AI_FALLBACK=true

# Dashboard/API local development
REQUIRE_DASHBOARD_AUTH=false
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DEFAULT_MAP_LAT=28.6139
DEFAULT_MAP_LNG=77.2090
HEATMAP_RADIUS=38
